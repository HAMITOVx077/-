<Window x:Class="МаршрутСборки.Views.Dialogs.TestResultDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Результат тестирования"
        Height="600" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8FAFC">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                Padding="24,18">
            <StackPanel>
                <TextBlock Text="Результат тестирования"
                           FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock x:Name="AssemblyNumberText"
                           FontSize="13" Foreground="#94A3B8"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Форма -->
        <StackPanel Grid.Row="1" Margin="24,20">

            <!-- Результат -->
            <TextBlock Text="Результат *" FontSize="13"
                       Foreground="#475569" Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <!-- Пройдено -->
                <Border x:Name="PassedBorder"
                        Background="#F0FDF4" BorderBrush="#86EFAC"
                        BorderThickness="2" CornerRadius="10"
                        Padding="20,14" Margin="0,0,12,0"
                        Cursor="Hand" Width="200"
                        MouseLeftButtonUp="Passed_Click">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="✓" FontSize="24"
                                   Foreground="#16A34A"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Пройдено" FontSize="14"
                                   FontWeight="SemiBold" Foreground="#16A34A"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                        <TextBlock Text="Сборка прошла проверку"
                                   FontSize="11" Foreground="#4ADE80"
                                   HorizontalAlignment="Center"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Не пройдено -->
                <Border x:Name="FailedBorder"
                        Background="#FFF7ED" BorderBrush="#FED7AA"
                        BorderThickness="1" CornerRadius="10"
                        Padding="20,14" Cursor="Hand" Width="200"
                        MouseLeftButtonUp="Failed_Click">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="✗" FontSize="24"
                                   Foreground="#EA580C"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Не пройдено" FontSize="14"
                                   FontWeight="SemiBold" Foreground="#EA580C"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                        <TextBlock Text="Требует доработки"
                                   FontSize="11" Foreground="#FB923C"
                                   HorizontalAlignment="Center"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Дефекты -->
            <TextBlock Text="Описание дефектов" FontSize="13"
                       Foreground="#475569" Margin="0,0,0,6"/>
            <Border Background="White" BorderBrush="#E2E8F0"
                    BorderThickness="1" CornerRadius="8"
                    Margin="0,0,0,16">
                <TextBox x:Name="DefectsBox"
                         FontSize="14" Padding="12,10"
                         BorderThickness="0" Background="Transparent"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         Height="80" VerticalScrollBarVisibility="Auto"/>
            </Border>

            <!-- Примечания -->
            <TextBlock Text="Примечания" FontSize="13"
                       Foreground="#475569" Margin="0,0,0,6"/>
            <Border Background="White" BorderBrush="#E2E8F0"
                    BorderThickness="1" CornerRadius="8">
                <TextBox x:Name="NotesBox"
                         FontSize="14" Padding="12,10"
                         BorderThickness="0" Background="Transparent"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         Height="60" VerticalScrollBarVisibility="Auto"/>
            </Border>

        </StackPanel>

        <!-- Кнопки -->
        <Border Grid.Row="2" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                Padding="24,16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" IsCancel="True"
                        Style="{StaticResource PrimaryButton}"
                        Background="#F1F5F9" Foreground="#475569"
                        Margin="0,0,10,0"/>
                <Button x:Name="SaveButton"
                        Content="Сохранить результат"
                        Click="Save_Click"
                        Style="{StaticResource PrimaryButton}"
                        Background="#8B5CF6"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>