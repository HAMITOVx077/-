<Window x:Class="МаршрутСборки.Views.Dialogs.NewUserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новый сотрудник"
        Height="550" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8FAFC">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                Padding="24,18">
            <StackPanel>
                <TextBlock Text="Новый сотрудник" FontSize="18"
                           FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock Text="Создать учётную запись"
                           FontSize="13" Foreground="#94A3B8"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="24,20">

            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Фамилия *" FontSize="13"
                               Foreground="#475569" Margin="0,0,0,6"/>
                    <Border Background="White" BorderBrush="#E2E8F0"
                            BorderThickness="1" CornerRadius="8">
                        <TextBox x:Name="LastNameBox" FontSize="14"
                                 Padding="12,10" BorderThickness="0"
                                 Background="Transparent"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Имя *" FontSize="13"
                               Foreground="#475569" Margin="0,0,0,6"/>
                    <Border Background="White" BorderBrush="#E2E8F0"
                            BorderThickness="1" CornerRadius="8">
                        <TextBox x:Name="FirstNameBox" FontSize="14"
                                 Padding="12,10" BorderThickness="0"
                                 Background="Transparent"/>
                    </Border>
                </StackPanel>
            </Grid>

            <TextBlock Text="Логин *" FontSize="13"
                       Foreground="#475569" Margin="0,0,0,6"/>
            <Border Background="White" BorderBrush="#E2E8F0"
                    BorderThickness="1" CornerRadius="8" Margin="0,0,0,14">
                <TextBox x:Name="LoginBox" FontSize="14" Padding="12,10"
                         BorderThickness="0" Background="Transparent"/>
            </Border>

            <TextBlock Text="Пароль *" FontSize="13"
                       Foreground="#475569" Margin="0,0,0,6"/>
            <Border Background="White" BorderBrush="#E2E8F0"
                    BorderThickness="1" CornerRadius="8" Margin="0,0,0,14">
                <PasswordBox x:Name="PasswordBox" FontSize="14"
                             Padding="12,10" BorderThickness="0"
                             Background="Transparent"/>
            </Border>

            <TextBlock Text="Роль *" FontSize="13"
                       Foreground="#475569" Margin="0,0,0,6"/>
            <Border Background="White" BorderBrush="#E2E8F0"
                    BorderThickness="1" CornerRadius="8">
                <ComboBox x:Name="RoleBox" FontSize="14" Padding="10,10"
                          BorderThickness="0" Background="Transparent"
                          DisplayMemberPath="RoleName"/>
            </Border>

        </StackPanel>

        <Border Grid.Row="2" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                Padding="24,16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" IsCancel="True"
                        Style="{StaticResource PrimaryButton}"
                        Background="#F1F5F9" Foreground="#475569"
                        Margin="0,0,10,0"/>
                <Button Content="Создать"
                        Click="Create_Click"
                        Style="{StaticResource PrimaryButton}"
                        Background="#3B82F6"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>