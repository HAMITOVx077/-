<Window x:Class="МаршрутСборки.Views.Dialogs.NewAssemblyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сборка"
        Height="680" Width="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8FAFC">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                Padding="24,18">
            <StackPanel>
                <TextBlock Text="{Binding DialogTitle}" FontSize="18"
                           FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock Text="{Binding DialogSubtitle}"
                           FontSize="13" Foreground="#94A3B8"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Форма -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Padding="24,20">
            <StackPanel>

                <!-- Клиент -->
                <TextBlock Text="Клиент *" FontSize="13"
                           Foreground="#475569" Margin="0,0,0,6"/>
                <Border Background="White" BorderBrush="#E2E8F0"
                        BorderThickness="1" CornerRadius="8"
                        Margin="0,0,0,16">
                    <TextBox Text="{Binding ClientName, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="14" Padding="12,10"
                             BorderThickness="0" Background="Transparent"/>
                </Border>

                <!-- Срок и приоритет -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Срок выполнения *" FontSize="13"
                                   Foreground="#475569" Margin="0,0,0,6"/>
                        <Border Background="White" BorderBrush="#E2E8F0"
                                BorderThickness="1" CornerRadius="8">
                            <DatePicker SelectedDate="{Binding Deadline}"
                                        FontSize="14" Padding="8,8"
                                        BorderThickness="0" Background="Transparent"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Приоритет" FontSize="13"
                                   Foreground="#475569" Margin="0,0,0,6"/>
                        <Border Background="White" BorderBrush="#E2E8F0"
                                BorderThickness="1" CornerRadius="8">
                            <ComboBox ItemsSource="{Binding Priorities}"
                                      SelectedItem="{Binding SelectedPriority}"
                                      FontSize="14" Padding="10,9"
                                      BorderThickness="0" Background="Transparent"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Примечания к конфигурации -->
                <TextBlock Text="Примечания к конфигурации" FontSize="13"
                           Foreground="#475569" Margin="0,0,0,6"/>
                <Border Background="White" BorderBrush="#E2E8F0"
                        BorderThickness="1" CornerRadius="8"
                        Margin="0,0,0,20">
                    <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="14" Padding="12,10"
                             BorderThickness="0" Background="Transparent"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             Height="80" VerticalScrollBarVisibility="Auto"/>
                </Border>

                <!-- Количество компьютеров — только при создании -->
                <Grid Margin="0,0,0,20"
                      Visibility="{Binding ShowQuantity,
                          Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Количество компьютеров" FontSize="13"
                                   FontWeight="SemiBold" Foreground="#1E293B"/>
                        <TextBlock Text="При количестве &gt; 1 создаётся партия с нумерацией /1, /2 ..."
                                   FontSize="11" Foreground="#94A3B8" Margin="0,3,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1" Background="White" BorderBrush="#E2E8F0"
                            BorderThickness="1" CornerRadius="8" Width="100">
                        <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="16" FontWeight="Bold" Padding="12,8"
                                 BorderThickness="0" Background="Transparent"
                                 TextAlignment="Center"/>
                    </Border>
                </Grid>

                <!-- Заголовок комплектующих -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Комплектующие" FontSize="13"
                               FontWeight="SemiBold" Foreground="#1E293B"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Content="+ Добавить"
                            Command="{Binding AddComponentCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Background="#3B82F6"
                            Height="32" Padding="14,0" FontSize="12"/>
                </Grid>

                <!-- Список комплектующих -->
                <Border Background="White" BorderBrush="#E2E8F0"
                        BorderThickness="1" CornerRadius="8"
                        MinHeight="80">
                    <ItemsControl ItemsSource="{Binding SelectedComponents}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#F1F5F9"
                                        BorderThickness="0,0,0,1"
                                        Padding="14,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="36"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Название и артикул -->
                                        <StackPanel Grid.Column="0"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,8,0">
                                            <TextBlock Text="{Binding Component.Name}"
                                                       FontSize="13" Foreground="#1E293B"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Component.SKU}"
                                                       FontSize="11" Foreground="#94A3B8"
                                                       Margin="0,3,0,0"/>
                                        </StackPanel>

                                        <!-- Количество -->
                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center">
                                            <TextBlock Text="Количество"
                                                       FontSize="10" Foreground="#94A3B8"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding Quantity}"
                                                       FontSize="14" FontWeight="Bold"
                                                       Foreground="#1E293B"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <!-- Кнопка удалить -->
                                        <Button Grid.Column="2"
                                                Content="✕"
                                                Command="{Binding DataContext.RemoveComponentCommand,
                                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Background="#FEF2F2" Foreground="#EF4444"
                                                BorderThickness="0"
                                                Width="30" Height="30"
                                                FontSize="11" Cursor="Hand"
                                                VerticalAlignment="Center">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}"
                                                                        CornerRadius="6">
                                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                                      VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#FEE2E2"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedComponents.Count}" Value="0">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate>
                                                    <TextBlock Text="Комплектующие не добавлены"
                                                               FontSize="13" Foreground="#94A3B8"
                                                               HorizontalAlignment="Center"
                                                               Margin="0,24"/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                    </ItemsControl>
                </Border>

                <!-- Ошибка -->
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#EF4444" FontSize="13"
                           Margin="0,12,0,0" TextWrapping="Wrap"
                           Visibility="{Binding ErrorMessage,
                               Converter={StaticResource StringToVisibilityConverter}}"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <Border Grid.Row="2" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                Padding="24,16">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Отмена"
                        IsCancel="True"
                        Background="#F1F5F9" Foreground="#475569"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,10,0"/>
                <Button Content="{Binding ConfirmButtonText}"
                        Command="{Binding CreateCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Background="#3B82F6"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>