<Window x:Class="МаршрутСборки.Views.Dialogs.ComponentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Позиция склада"
        Height="550" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8FAFC">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                Padding="24,18">
            <StackPanel>
                <TextBlock x:Name="TitleText" FontSize="18"
                           FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock x:Name="SubtitleText"
                           FontSize="13" Foreground="#94A3B8"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="24,20">

            <TextBlock Text="Артикул (SKU) *" FontSize="13"
                       Foreground="#475569" Margin="0,0,0,6"/>
            <Border Background="White" BorderBrush="#E2E8F0"
                    BorderThickness="1" CornerRadius="8" Margin="0,0,0,14">
                <TextBox x:Name="SKUBox" FontSize="14" Padding="12,10"
                         BorderThickness="0" Background="Transparent"/>
            </Border>

            <TextBlock Text="Наименование *" FontSize="13"
                       Foreground="#475569" Margin="0,0,0,6"/>
            <Border Background="White" BorderBrush="#E2E8F0"
                    BorderThickness="1" CornerRadius="8" Margin="0,0,0,14">
                <TextBox x:Name="NameBox" FontSize="14" Padding="12,10"
                         BorderThickness="0" Background="Transparent"/>
            </Border>

            <TextBlock Text="Категория *" FontSize="13"
                       Foreground="#475569" Margin="0,0,0,6"/>
            <Border Background="White" BorderBrush="#E2E8F0"
                    BorderThickness="1" CornerRadius="8" Margin="0,0,0,14">
                <ComboBox x:Name="CategoryBox" FontSize="14" Padding="10,10"
                          BorderThickness="0" Background="Transparent"
                          IsEditable="True">
                    <ComboBoxItem>Процессор</ComboBoxItem>
                    <ComboBoxItem>Материнская плата</ComboBoxItem>
                    <ComboBoxItem>Оперативная память</ComboBoxItem>
                    <ComboBoxItem>Накопитель</ComboBoxItem>
                    <ComboBoxItem>Видеокарта</ComboBoxItem>
                    <ComboBoxItem>Блок питания</ComboBoxItem>
                    <ComboBoxItem>Корпус</ComboBoxItem>
                    <ComboBoxItem>Охлаждение</ComboBoxItem>
                    <ComboBoxItem>Периферия</ComboBoxItem>
                    <ComboBoxItem>Прочее</ComboBoxItem>
                </ComboBox>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Цена (₽) *" FontSize="13"
                               Foreground="#475569" Margin="0,0,0,6"/>
                    <Border Background="White" BorderBrush="#E2E8F0"
                            BorderThickness="1" CornerRadius="8">
                        <TextBox x:Name="PriceBox" FontSize="14" Padding="12,10"
                                 BorderThickness="0" Background="Transparent"
                                 Text="0"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Остаток" FontSize="13"
                               Foreground="#475569" Margin="0,0,0,6"/>
                    <Border Background="White" BorderBrush="#E2E8F0"
                            BorderThickness="1" CornerRadius="8">
                        <TextBox x:Name="StockBox" FontSize="14" Padding="12,10"
                                 BorderThickness="0" Background="Transparent"
                                 Text="0"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock Text="Мин. остаток" FontSize="13"
                               Foreground="#475569" Margin="0,0,0,6"/>
                    <Border Background="White" BorderBrush="#E2E8F0"
                            BorderThickness="1" CornerRadius="8">
                        <TextBox x:Name="MinStockBox" FontSize="14" Padding="12,10"
                                 BorderThickness="0" Background="Transparent"
                                 Text="5"/>
                    </Border>
                </StackPanel>
            </Grid>

        </StackPanel>

        <Border Grid.Row="2" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                Padding="24,16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" IsCancel="True"
                        Style="{StaticResource PrimaryButton}"
                        Background="#F1F5F9" Foreground="#475569"
                        Margin="0,0,10,0"/>
                <Button x:Name="SaveButton"
                        Click="Save_Click"
                        Style="{StaticResource PrimaryButton}"
                        Background="#3B82F6"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>