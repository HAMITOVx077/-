<Window x:Class="МаршрутСборки.Views.Dialogs.UpdateWarrantyStatusDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Обновить статус"
        Height="450" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8FAFC">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                Padding="24,18">
            <StackPanel>
                <TextBlock Text="Обновить статус обращения"
                           FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock x:Name="CaseNumberText"
                           FontSize="13" Foreground="#94A3B8"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="24,20">

            <TextBlock Text="Новый статус *" FontSize="13"
                       Foreground="#475569" Margin="0,0,0,6"/>
            <Border Background="White" BorderBrush="#E2E8F0"
                    BorderThickness="1" CornerRadius="8" Margin="0,0,0,16">
                <ComboBox x:Name="StatusBox" FontSize="14" Padding="10,10"
                          BorderThickness="0" Background="Transparent">
                    <ComboBoxItem>Принято</ComboBoxItem>
                    <ComboBoxItem>Диагностика</ComboBoxItem>
                    <ComboBoxItem>В ремонте</ComboBoxItem>
                    <ComboBoxItem>Готово к выдаче</ComboBoxItem>
                    <ComboBoxItem>Закрыто</ComboBoxItem>
                </ComboBox>
            </Border>

            <TextBlock Text="Заметки по ремонту" FontSize="13"
                       Foreground="#475569" Margin="0,0,0,6"/>
            <Border Background="White" BorderBrush="#E2E8F0"
                    BorderThickness="1" CornerRadius="8">
                <TextBox x:Name="RepairNotesBox" FontSize="14" Padding="12,10"
                         BorderThickness="0" Background="Transparent"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         Height="100" VerticalScrollBarVisibility="Auto"/>
            </Border>

        </StackPanel>

        <Border Grid.Row="2" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                Padding="24,16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" IsCancel="True"
                        Style="{StaticResource PrimaryButton}"
                        Background="#F1F5F9" Foreground="#475569"
                        Margin="0,0,10,0"/>
                <Button Content="Сохранить"
                        Click="Save_Click"
                        Style="{StaticResource PrimaryButton}"
                        Background="#F59E0B"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>