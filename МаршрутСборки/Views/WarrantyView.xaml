<UserControl x:Class="МаршрутСборки.Views.WarrantyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:МаршрутСборки.ViewModels">
    <UserControl.DataContext>
        <vm:WarrantyViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- Левая часть -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0" Background="White"
                    BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                    Padding="32,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Гарантия и ремонт" FontSize="22"
                                   FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="Учёт гарантийных обращений клиентов"
                                   FontSize="13" Foreground="#94A3B8"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="+ Новое обращение"
                            Command="{Binding CreateCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Background="#3B82F6"/>
                </Grid>
            </Border>

            <!-- Таблица -->
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Cases}"
                      SelectedItem="{Binding SelectedCase}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      Background="White"
                      RowBackground="White"
                      AlternatingRowBackground="#FAFAFA"
                      BorderThickness="0"
                      ColumnHeaderHeight="44"
                      RowHeight="52"
                      SelectionMode="Single"
                      CanUserResizeRows="False">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="Foreground" Value="#64748B"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="16,0"/>
                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#EFF6FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="16,0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Padding="{TemplateBinding Padding}"
                                            Background="{TemplateBinding Background}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Номер" Width="130"
                                        Binding="{Binding CaseNumber}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#1E293B"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Клиент" Width="*"
                                        Binding="{Binding ClientName}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#475569"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="Статус" Width="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="20" Padding="10,4"
                                        HorizontalAlignment="Left"
                                        Background="{Binding Status,
                                            Converter={StaticResource WarrantyStatusColorConverter}}">
                                    <TextBlock Text="{Binding Status}"
                                               Foreground="White" FontSize="12"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Инженер" Width="140"
                                        Binding="{Binding Engineer.FullName}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#475569"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Дата обращения" Width="130"
                                        Binding="{Binding ReceivedDate, StringFormat=dd.MM.yyyy}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#94A3B8"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Панель действий -->
            <Border Grid.Row="2" Background="White"
                    BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                    Padding="32,14">
                <StackPanel Orientation="Horizontal">
                    <Button Content="{Binding AssignReworkLabel}"
                            Command="{Binding AssignReworkCommand}"
                            Visibility="{Binding CanAssignRework,
                                Converter={StaticResource BoolToVisibilityConverter}}"
                            Style="{StaticResource PrimaryButton}"
                            Background="#8B5CF6"
                            Margin="0,0,10,0"
                            ToolTip="Открыть диалог замены компонентов и поставить сборку в переделку"/>
<Button Content="Удалить"
                            Command="{Binding DeleteCommand}"
                            Visibility="{Binding CanDelete,
                                Converter={StaticResource BoolToVisibilityConverter}}"
                            Style="{StaticResource PrimaryButton}"
                            Background="#EF4444"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Правая панель — детали -->
        <Border Grid.Column="1"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1,0,0,0">
            <Grid>
                <!-- Если ничего не выбрано -->
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Visibility="{Binding SelectedCase,
                                Converter={StaticResource NullToVisibilityConverter}}">
                    <TextBlock Text="🛡" FontSize="40"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Выберите обращение"
                               FontSize="14" Foreground="#94A3B8"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                    <TextBlock Text="для просмотра деталей"
                               FontSize="13" Foreground="#CBD5E1"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Детали -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding SelectedCase,
                                  Converter={StaticResource NotNullToVisibilityConverter}}">
                    <StackPanel Margin="20">

                        <TextBlock Text="{Binding SelectedCase.CaseNumber}"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="#1E293B" Margin="0,0,0,6"/>

                        <Border CornerRadius="20" Padding="10,4"
                                HorizontalAlignment="Left" Margin="0,0,0,16"
                                Background="{Binding SelectedCase.Status,
                                    Converter={StaticResource WarrantyStatusColorConverter}}">
                            <TextBlock Text="{Binding SelectedCase.Status}"
                                       Foreground="White" FontSize="12"
                                       FontWeight="SemiBold"/>
                        </Border>

                        <TextBlock Text="Клиент" FontSize="11"
                                   Foreground="#94A3B8" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SelectedCase.ClientName}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="#1E293B" Margin="0,0,0,14"
                                   TextWrapping="Wrap"/>

                        <TextBlock Text="Телефон" FontSize="11"
                                   Foreground="#94A3B8" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SelectedCase.ClientPhone}"
                                   FontSize="13" Foreground="#475569"
                                   Margin="0,0,0,14"/>

                        <TextBlock Text="Инженер" FontSize="11"
                                   Foreground="#94A3B8" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SelectedCase.Engineer.FullName}"
                                   FontSize="13" Foreground="#475569"
                                   Margin="0,0,0,14"/>

                        <TextBlock Text="Дата обращения" FontSize="11"
                                   Foreground="#94A3B8" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SelectedCase.ReceivedDate, StringFormat=dd.MM.yyyy}"
                                   FontSize="13" Foreground="#475569"
                                   Margin="0,0,0,14"/>

                        <TextBlock Text="Дата закрытия" FontSize="11"
                                   Foreground="#94A3B8" Margin="0,0,0,4"
                                   Visibility="{Binding SelectedCase.ClosedDate,
                                       Converter={StaticResource NotNullToVisibilityConverter}}"/>
                        <TextBlock Text="{Binding SelectedCase.ClosedDate, StringFormat=dd.MM.yyyy}"
                                   FontSize="13" Foreground="#475569"
                                   Margin="0,0,0,14"
                                   Visibility="{Binding SelectedCase.ClosedDate,
                                       Converter={StaticResource NotNullToVisibilityConverter}}"/>

                        <Border Height="1" Background="#E2E8F0" Margin="0,0,0,14"/>

                        <TextBlock Text="Описание проблемы" FontSize="11"
                                   Foreground="#94A3B8" Margin="0,0,0,4"/>
                        <Border Background="#FEF2F2" CornerRadius="8"
                                Padding="12,10" Margin="0,0,0,14">
                            <TextBlock Text="{Binding SelectedCase.ProblemDescription}"
                                       FontSize="13" Foreground="#475569"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <TextBlock Text="Заметки по ремонту" FontSize="11"
                                   Foreground="#94A3B8" Margin="0,0,0,4"
                                   Visibility="{Binding SelectedCase.RepairNotes,
                                       Converter={StaticResource StringToVisibilityConverter}}"/>
                        <Border Background="#F0FDF4" CornerRadius="8"
                                Padding="12,10" Margin="0,0,0,14"
                                Visibility="{Binding SelectedCase.RepairNotes,
                                    Converter={StaticResource StringToVisibilityConverter}}">
                            <TextBlock Text="{Binding SelectedCase.RepairNotes}"
                                       FontSize="13" Foreground="#475569"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <!-- История переписки -->
                        <Border Height="1" Background="#E2E8F0" Margin="0,0,0,14"/>
                        <TextBlock Text="История обращения" FontSize="11"
                                   Foreground="#94A3B8" FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>

                        <ItemsControl ItemsSource="{Binding Notes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8FAFC" CornerRadius="8"
                                            BorderBrush="#E2E8F0" BorderThickness="1"
                                            Padding="10,8" Margin="0,0,0,6">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Author.FullName}"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="#3B82F6"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}"
                                                           FontSize="10" Foreground="#94A3B8"/>
                                            </Grid>
                                            <TextBlock Text="{Binding Text}"
                                                       FontSize="12" Foreground="#1E293B"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Добавить заметку — только для активных обращений -->
                        <Border Background="#F1F5F9" CornerRadius="8"
                                BorderBrush="#CBD5E1" BorderThickness="1"
                                Padding="10,8" Margin="0,6,0,14"
                                Visibility="{Binding CanAddNote,
                                    Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <Grid MinHeight="54">
                                    <TextBlock Text="Добавить заметку к обращению..."
                                               FontSize="12" Foreground="#94A3B8"
                                               Margin="6,6,0,0"
                                               VerticalAlignment="Top"
                                               IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding NewNoteText}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBox Text="{Binding NewNoteText, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="12" Padding="4"
                                             BorderThickness="0" Background="Transparent"
                                             TextWrapping="Wrap" AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"/>
                                </Grid>
                                <Button Content="Добавить заметку"
                                        Command="{Binding AddNoteCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Background="#3B82F6"
                                        HorizontalAlignment="Right"
                                        Margin="0,6,0,0"
                                        Padding="12,6"/>
                            </StackPanel>
                        </Border>

                        <!-- Связанная сборка -->
                        <Border Height="1" Background="#E2E8F0" Margin="0,0,0,14"
                                Visibility="{Binding SelectedCase.Assembly,
                                    Converter={StaticResource NotNullToVisibilityConverter}}"/>

                        <TextBlock Text="Связанная сборка" FontSize="11"
                                   Foreground="#94A3B8" Margin="0,0,0,8"
                                   Visibility="{Binding SelectedCase.Assembly,
                                       Converter={StaticResource NotNullToVisibilityConverter}}"/>

                        <Border Background="#EFF6FF" CornerRadius="8"
                                Padding="14,12" Margin="0,0,0,10"
                                Visibility="{Binding SelectedCase.Assembly,
                                    Converter={StaticResource NotNullToVisibilityConverter}}">
                            <StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Номер: " FontSize="12"
                                               Foreground="#64748B"/>
                                    <TextBlock Text="{Binding SelectedCase.Assembly.AssemblyNumber}"
                                               FontSize="12" FontWeight="Bold"
                                               Foreground="#3B82F6"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Клиент: " FontSize="12"
                                               Foreground="#64748B"/>
                                    <TextBlock Text="{Binding SelectedCase.Assembly.ClientName}"
                                               FontSize="12" Foreground="#1E293B"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Собрал: " FontSize="12"
                                               Foreground="#64748B"/>
                                    <TextBlock Text="{Binding SelectedCase.Assembly.Assembler.FullName}"
                                               FontSize="12" Foreground="#1E293B"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Дата: " FontSize="12"
                                               Foreground="#64748B"/>
                                    <TextBlock Text="{Binding SelectedCase.Assembly.CreationDate, StringFormat=dd.MM.yyyy}"
                                               FontSize="12" Foreground="#1E293B"/>
                                </StackPanel>

                                <Border Height="1" Background="#BFDBFE" Margin="0,0,0,10"/>

                                <TextBlock Text="Состав сборки:" FontSize="12"
                                           FontWeight="SemiBold" Foreground="#1E293B"
                                           Margin="0,0,0,6"/>

                                <ItemsControl ItemsSource="{Binding SelectedCase.Assembly.AssemblyComponents}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Component.Name}"
                                                           FontSize="12" Foreground="#475569"
                                                           TextWrapping="Wrap"/>
                                                <Border Grid.Column="1"
                                                        Background="#3B82F6"
                                                        CornerRadius="10" Padding="6,2"
                                                        Margin="6,0,0,0"
                                                        VerticalAlignment="Center">
                                                    <TextBlock FontSize="11"
                                                               Foreground="White"
                                                               FontWeight="SemiBold">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="x{0}">
                                                                <Binding Path="Quantity"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Результаты тестирования сборки -->
                                <Border Height="1" Background="#BFDBFE" Margin="0,10,0,10"/>

                                <TextBlock Text="Тестирование:" FontSize="12"
                                           FontWeight="SemiBold" Foreground="#1E293B"
                                           Margin="0,0,0,6"/>

                                <ItemsControl ItemsSource="{Binding SelectedCase.Assembly.Tests}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="6" Padding="10,8" Margin="0,0,0,6">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Result}" Value="Пройдено">
                                                                <Setter Property="Background" Value="#F0FDF4"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Result}" Value="Не пройдено">
                                                                <Setter Property="Background" Value="#FEF2F2"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <TextBlock FontSize="12" FontWeight="Bold" Margin="0,0,0,4">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Result}" Value="Пройдено">
                                                                        <Setter Property="Text" Value="✓ Пройдено"/>
                                                                        <Setter Property="Foreground" Value="#16A34A"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Result}" Value="Не пройдено">
                                                                        <Setter Property="Text" Value="✗ Не пройдено"/>
                                                                        <Setter Property="Foreground" Value="#EF4444"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                        <TextBlock Text="Дата: " FontSize="11" Foreground="#64748B"/>
                                                        <TextBlock Text="{Binding TestDate, StringFormat=dd.MM.yyyy HH:mm}"
                                                                   FontSize="11" Foreground="#475569"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Тестировщик: " FontSize="11" Foreground="#64748B"/>
                                                        <TextBlock Text="{Binding Tester.FullName}"
                                                                   FontSize="11" Foreground="#1E293B" FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Defects}"
                                                               FontSize="11" Foreground="#DC2626" FontWeight="SemiBold"
                                                               TextWrapping="Wrap" Margin="0,4,0,0"
                                                               Visibility="{Binding Defects,
                                                                   Converter={StaticResource StringToVisibilityConverter}}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>