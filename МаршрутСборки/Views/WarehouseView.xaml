<UserControl x:Class="МаршрутСборки.Views.WarehouseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:МаршрутСборки.ViewModels">
    <UserControl.DataContext>
        <vm:WarehouseViewModel/>
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="280"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="220"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="220"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                Padding="32,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Склад" FontSize="22"
                               FontWeight="Bold" Foreground="#1E293B"/>
                    <TextBlock Text="Учёт комплектующих и материалов"
                               FontSize="13" Foreground="#94A3B8"
                               Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="+ Добавить позицию"
                        Command="{Binding AddComponentCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Background="#3B82F6"/>
            </Grid>
        </Border>

        <!-- Фильтр + предупреждение -->
        <Border Grid.Row="1" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                Padding="32,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#F8FAFC"
                        BorderBrush="#E2E8F0" BorderThickness="1"
                        CornerRadius="8" Margin="0,0,16,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍"
                                   FontSize="14" Margin="12,0,6,0"
                                   VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="13" Padding="4,8"
                                 BorderThickness="0" Background="Transparent"/>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Background="#FEF2F2"
                        BorderBrush="#FECACA" BorderThickness="1"
                        CornerRadius="8" Padding="14,8"
                        Visibility="{Binding HasLowStock,
                            Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠" FontSize="14"
                                   Foreground="#EF4444"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0"/>
                        <TextBlock FontSize="13" Foreground="#DC2626"
                                   VerticalAlignment="Center">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="Мало на складе: {0} поз.">
                                    <Binding Path="LowStockCount"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Таблица комплектующих -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Components}"
                  SelectedItem="{Binding SelectedComponent}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  Background="White"
                  RowBackground="White"
                  AlternatingRowBackground="#FAFAFA"
                  BorderThickness="0"
                  ColumnHeaderHeight="44"
                  RowHeight="52"
                  SelectionMode="Single"
                  CanUserResizeRows="False">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="Foreground" Value="#64748B"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="16,0"/>
                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Cursor" Value="Hand"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#EFF6FF"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F8FAFC"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="16,0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border Padding="{TemplateBinding Padding}"
                                        Background="{TemplateBinding Background}">
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Артикул" Width="120"
                                    Binding="{Binding SKU}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#94A3B8"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Наименование" Width="*"
                                    Binding="{Binding Name}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="#1E293B"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Категория" Width="140"
                                    Binding="{Binding Category}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#475569"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Цена" Width="100"
                                    Binding="{Binding Price, StringFormat={}{0:N0} ₽}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#475569"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="Остаток" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Border Width="10" Height="10"
                                        CornerRadius="5" Margin="0,0,8,0"
                                        Background="{Binding IsLowStock,
                                            Converter={StaticResource StockLevelColorConverter}}"/>
                                <TextBlock Text="{Binding StockBalance}"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="{Binding IsLowStock,
                                               Converter={StaticResource StockLevelColorConverter}}"/>
                                <TextBlock Text=" шт." FontSize="13"
                                           Foreground="#94A3B8"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Мин. остаток" Width="110"
                                    Binding="{Binding MinStock, StringFormat={}{0} шт.}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#94A3B8"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Панель действий склада -->
        <Border Grid.Row="3" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                Padding="32,14">
            <StackPanel Orientation="Horizontal">
                <Button Content="Принять поставку"
                        Command="{Binding ReceiveDeliveryCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Background="#16A34A"
                        Margin="0,0,10,0"/>
                <Button Content="Редактировать"
                        Command="{Binding EditComponentCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Background="#F59E0B"/>
            </StackPanel>
        </Border>

        <!-- Секция выдачи под сборку -->
        <Border Grid.Row="4" Background="#F8FAFC"
                BorderBrush="#E2E8F0" BorderThickness="0,2,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="32,12"
                        BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                        Background="White">
                    <TextBlock Text="Выдача комплектующих под сборку"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="#1E293B"/>
                </Border>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding PendingAssemblies}"
                          SelectedItem="{Binding SelectedPendingAssembly}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          Background="White"
                          RowBackground="White"
                          BorderThickness="0"
                          ColumnHeaderHeight="36"
                          RowHeight="44"
                          SelectionMode="Single"
                          CanUserResizeRows="False">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="#64748B"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="16,0"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#EFF6FF"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="16,0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="{TemplateBinding Padding}"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Номер сборки" Width="140"
                                            Binding="{Binding AssemblyNumber}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="#1E293B"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Клиент" Width="*"
                                            Binding="{Binding ClientName}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#475569"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="Статус" Width="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="20" Padding="8,3"
                                            HorizontalAlignment="Left"
                                            Background="{Binding Status,
                                                Converter={StaticResource StatusColorConverter}}">
                                        <TextBlock Text="{Binding Status}"
                                                   Foreground="White" FontSize="11"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Сборщик" Width="160"
                                            Binding="{Binding Assembler.FullName}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#475569"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Панель выдачи -->
        <Border Grid.Row="5" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,1,0,1"
                Padding="32,14">
            <StackPanel Orientation="Horizontal">
                <Button Content="Выдать комплектующие"
                        Command="{Binding IssueComponentsCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Background="#3B82F6"/>
            </StackPanel>
        </Border>

        <!-- Секция переделок -->
        <Border Grid.Row="6" Background="#FFF7ED"
                BorderBrush="#FED7AA" BorderThickness="0,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="32,10"
                        BorderBrush="#FED7AA" BorderThickness="0,0,0,1"
                        Background="#FEF3C7">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="🔧 " FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Переделки — замена компонентов"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="#92400E" VerticalAlignment="Center"/>
                            <Border Background="#F59E0B" CornerRadius="10"
                                    Padding="8,2" Margin="10,0,0,0"
                                    Visibility="{Binding HasRework,
                                        Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="{Binding ReworkCount}"
                                           Foreground="White" FontSize="11"
                                           FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text="Выберите сборку → увидите что нужно выдать"
                                   FontSize="11" Foreground="#B45309"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Список сборок на переделку -->
                    <DataGrid Grid.Column="0"
                              ItemsSource="{Binding ReworkAssemblies}"
                              SelectedItem="{Binding SelectedReworkAssembly}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              Background="White" RowBackground="White"
                              BorderThickness="0"
                              ColumnHeaderHeight="34" RowHeight="40"
                              SelectionMode="Single" CanUserResizeRows="False">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#FFFBEB"/>
                                <Setter Property="Foreground" Value="#92400E"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="12,0"/>
                                <Setter Property="BorderBrush" Value="#FED7AA"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#FEF3C7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="12,0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Padding="{TemplateBinding Padding}"
                                                    Background="{TemplateBinding Background}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Сборка" Width="130"
                                                Binding="{Binding AssemblyNumber}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="#92400E"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Клиент" Width="*"
                                                Binding="{Binding ClientName}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#475569"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Column="1" Background="#FED7AA"/>

                    <!-- Детали замены выбранной сборки -->
                    <DataGrid Grid.Column="2"
                              ItemsSource="{Binding SelectedReworkItems}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              Background="White" RowBackground="White"
                              BorderThickness="0"
                              ColumnHeaderHeight="34" RowHeight="40"
                              CanUserResizeRows="False">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#FFFBEB"/>
                                <Setter Property="Foreground" Value="#92400E"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="12,0"/>
                                <Setter Property="BorderBrush" Value="#FED7AA"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="12,0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Padding="{TemplateBinding Padding}"
                                                    Background="{TemplateBinding Background}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Снять" Width="*"
                                                Binding="{Binding OldComponent.Name}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#EF4444"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Выдать" Width="*"
                                                Binding="{Binding NewComponent.Name}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#16A34A"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Кол" Width="50"
                                                Binding="{Binding Quantity}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#475569"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Grid>
        </Border>

        <!-- Панель действий переделки -->
        <Border Grid.Row="7" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                Padding="32,14">
            <StackPanel Orientation="Horizontal">
                <Button Content="🔧 Выдать замену"
                        Command="{Binding IssueReworkCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Background="#F59E0B" Margin="0,0,10,0"
                        ToolTip="Выдать новые компоненты и вернуть старые на склад"/>
                <Button Content="📄 Акт переделки"
                        Command="{Binding PrintReworkActCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Background="#475569"/>
            </StackPanel>
        </Border>
    </Grid>
    </ScrollViewer>
</UserControl>