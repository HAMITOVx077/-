<UserControl x:Class="МаршрутСборки.Views.AssembliesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:МаршрутСборки.ViewModels">
    <UserControl.DataContext>
        <vm:AssembliesViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- Левая часть — список сборок -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0" Background="White"
                    BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                    Padding="32,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding PageTitle}" FontSize="22"
                                   FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="{Binding PageSubtitle}"
                                   FontSize="13" Foreground="#94A3B8"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="+ Создать новую сборку"
                            Command="{Binding CreateCommand}"
                            Visibility="{Binding CanCreate,
                                Converter={StaticResource BoolToVisibilityConverter}}"
                            Style="{StaticResource PrimaryButton}"
                            Background="#3B82F6"/>
                </Grid>
            </Border>

            <!-- Фильтры -->
            <Border Grid.Row="1" Background="White"
                    BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                    Padding="32,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#F8FAFC"
                            BorderBrush="#E2E8F0" BorderThickness="1"
                            CornerRadius="8" Margin="0,0,12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🔍"
                                       FontSize="14" Margin="12,0,6,0"
                                       VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="13" Padding="4,8"
                                     BorderThickness="0" Background="Transparent"/>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Background="#F8FAFC"
                            BorderBrush="#E2E8F0" BorderThickness="1"
                            CornerRadius="8">
                        <ComboBox ItemsSource="{Binding StatusFilters}"
                                  SelectedItem="{Binding SelectedStatusFilter}"
                                  FontSize="13" Padding="10,8"
                                  BorderThickness="0" Background="Transparent"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Таблица -->
            <DataGrid Grid.Row="2"
                      x:Name="AssembliesGrid"
                      ItemsSource="{Binding Assemblies}"
                      SelectedItem="{Binding SelectedAssembly}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      Background="White"
                      RowBackground="White"
                      AlternatingRowBackground="#FAFAFA"
                      BorderThickness="0"
                      ColumnHeaderHeight="44"
                      RowHeight="48"
                      SelectionMode="Extended"
                      CanUserResizeRows="False"
                      SelectionChanged="AssembliesGrid_SelectionChanged">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="Foreground" Value="#64748B"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="16,0"/>
                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#EFF6FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="16,0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Padding="{TemplateBinding Padding}"
                                            Background="{TemplateBinding Background}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Номер" Width="120"
                                        Binding="{Binding AssemblyNumber}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#1E293B"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Клиент" Width="*"
                                        Binding="{Binding ClientName}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#475569"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="Статус" Width="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="20" Padding="10,4"
                                        HorizontalAlignment="Left"
                                        Background="{Binding Status,
                                            Converter={StaticResource StatusColorConverter}}">
                                    <TextBlock Text="{Binding Status}"
                                               Foreground="White" FontSize="12"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Приоритет" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="20" Padding="10,4"
                                        HorizontalAlignment="Left"
                                        Background="{Binding Priority,
                                            Converter={StaticResource PriorityColorConverter}}">
                                    <TextBlock Text="{Binding Priority}"
                                               Foreground="White" FontSize="12"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Срок" Width="100"
                                        Binding="{Binding Deadline, StringFormat=dd.MM.yyyy}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#475569"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Баннер ожидания выдачи комплектующих -->
            <Border Grid.Row="3" Background="#FFF7ED"
                    BorderBrush="#F59E0B" BorderThickness="0,1,0,0"
                    Padding="32,10"
                    Visibility="{Binding ShowWaitingForComponents,
                        Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⏳" FontSize="15" VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBlock Text="Ожидайте выдачи комплектующих кладовщиком перед завершением сборки"
                               FontSize="13" Foreground="#92400E" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Панель действий -->
            <Border Grid.Row="4" Background="White"
        BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
        Padding="32,14">
                <StackPanel Orientation="Horizontal">
                    <Button Content="✏ Редактировать"
                Command="{Binding EditCommand}"
                Visibility="{Binding CanEdit,
                    Converter={StaticResource BoolToVisibilityConverter}}"
                Style="{StaticResource PrimaryButton}"
                Background="#0EA5E9"
                Margin="0,0,10,0"/>
                    <Button Content="Принять в работу"
                Command="{Binding AcceptCommand}"
                Visibility="{Binding CanAccept,
                    Converter={StaticResource BoolToVisibilityConverter}}"
                Style="{StaticResource PrimaryButton}"
                Background="#3B82F6"
                Margin="0,0,10,0"/>
                    <Button Content="Взять на доработку"
                Command="{Binding ReworkCommand}"
                Visibility="{Binding CanRework,
                    Converter={StaticResource BoolToVisibilityConverter}}"
                Style="{StaticResource PrimaryButton}"
                Background="#F59E0B"
                Margin="0,0,10,0"/>
                    <Button Content="Завершить сборку"
                Command="{Binding CompleteCommand}"
                Visibility="{Binding CanComplete,
                    Converter={StaticResource BoolToVisibilityConverter}}"
                Style="{StaticResource PrimaryButton}"
                Background="#16A34A"
                Margin="0,0,10,0"/>
                    <Button Content="На тестирование"
                Command="{Binding SendToTestCommand}"
                Visibility="{Binding CanSendToTest,
                    Converter={StaticResource BoolToVisibilityConverter}}"
                Style="{StaticResource PrimaryButton}"
                Background="#8B5CF6"
                Margin="0,0,10,0"/>
                    <Button Content="Удалить"
                Command="{Binding DeleteCommand}"
                Visibility="{Binding CanDelete,
                    Converter={StaticResource BoolToVisibilityConverter}}"
                Style="{StaticResource PrimaryButton}"
                Background="#EF4444"
                Margin="0,0,10,0"/>
                    <Button Content="{Binding ShipSelectedLabel}"
                Command="{Binding ShipSelectedCommand}"
                Visibility="{Binding CanShipSelected,
                    Converter={StaticResource BoolToVisibilityConverter}}"
                Style="{StaticResource PrimaryButton}"
                Background="#0F766E"
                Margin="0,0,10,0"/>
                    <Button Content="Отправить все готовые"
                Command="{Binding ShipAllReadyCommand}"
                Visibility="{Binding CanShipAllReady,
                    Converter={StaticResource BoolToVisibilityConverter}}"
                Style="{StaticResource PrimaryButton}"
                Background="#0F766E"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Правая панель — детали сборки -->
        <Border Grid.Column="1"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1,0,0,0">
            <Grid>

                <!-- Если ничего не выбрано -->
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Visibility="{Binding SelectedAssembly,
                                Converter={StaticResource NullToVisibilityConverter}}">
                    <TextBlock Text="📋" FontSize="40"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Выберите сборку"
                               FontSize="14" Foreground="#94A3B8"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                    <TextBlock Text="для просмотра деталей"
                               FontSize="13" Foreground="#CBD5E1"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Детали выбранной сборки -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding SelectedAssembly,
                                  Converter={StaticResource NotNullToVisibilityConverter}}">
                    <StackPanel Margin="20">

                        <!-- Номер -->
                        <TextBlock Text="{Binding SelectedAssembly.AssemblyNumber}"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="#1E293B" Margin="0,0,0,6"/>

                        <!-- Статус -->
                        <Border CornerRadius="20" Padding="10,4"
                                HorizontalAlignment="Left" Margin="0,0,0,16"
                                Background="{Binding SelectedAssembly.Status,
                                    Converter={StaticResource StatusColorConverter}}">
                            <TextBlock Text="{Binding SelectedAssembly.Status}"
                                       Foreground="White" FontSize="12"
                                       FontWeight="SemiBold"/>
                        </Border>

                        <!-- Клиент -->
                        <TextBlock Text="Клиент" FontSize="11"
                                   Foreground="#94A3B8" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SelectedAssembly.ClientName}"
                                   FontSize="14" Foreground="#1E293B"
                                   FontWeight="SemiBold" Margin="0,0,0,14"
                                   TextWrapping="Wrap"/>

                        <!-- Сборщик -->
                        <TextBlock Text="Сборщик" FontSize="11"
                                   Foreground="#94A3B8" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SelectedAssembly.Assembler.FullName}"
                                   FontSize="13" Foreground="#475569"
                                   Margin="0,0,0,14"/>

                        <!-- Диспетчер -->
                        <TextBlock Text="Диспетчер" FontSize="11"
                                   Foreground="#94A3B8" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SelectedAssembly.Dispatcher.FullName}"
                                   FontSize="13" Foreground="#475569"
                                   Margin="0,0,0,14"/>

                        <!-- Срок -->
                        <TextBlock Text="Срок выполнения" FontSize="11"
                                   Foreground="#94A3B8" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SelectedAssembly.Deadline, StringFormat=dd.MM.yyyy}"
                                   FontSize="13" Foreground="#475569"
                                   Margin="0,0,0,14"/>

                        <!-- Приоритет -->
                        <TextBlock Text="Приоритет" FontSize="11"
                                   Foreground="#94A3B8" Margin="0,0,0,4"/>
                        <Border CornerRadius="20" Padding="10,4"
                                HorizontalAlignment="Left" Margin="0,0,0,14"
                                Background="{Binding SelectedAssembly.Priority,
                                    Converter={StaticResource PriorityColorConverter}}">
                            <TextBlock Text="{Binding SelectedAssembly.Priority}"
                                       Foreground="White" FontSize="12"
                                       FontWeight="SemiBold"/>
                        </Border>

                        <!-- Примечания -->
                        <TextBlock Text="Примечания к конфигурации" FontSize="11"
                                   Foreground="#94A3B8" Margin="0,0,0,4"
                                   Visibility="{Binding SelectedAssembly.Notes,
                                       Converter={StaticResource StringToVisibilityConverter}}"/>
                        <Border Background="#F8FAFC" CornerRadius="8"
                                Padding="12,10" Margin="0,0,0,14"
                                Visibility="{Binding SelectedAssembly.Notes,
                                    Converter={StaticResource StringToVisibilityConverter}}">
                            <TextBlock Text="{Binding SelectedAssembly.Notes}"
                                       FontSize="13" Foreground="#475569"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <!-- Разделитель -->
                        <Border Height="1" Background="#E2E8F0" Margin="0,14,0,14"/>

                        <!-- Результат тестирования — показывается если есть тесты -->
                        <Border Height="1" Background="#E2E8F0" Margin="0,0,0,14"
        Visibility="{Binding SelectedAssembly.Tests,
            Converter={StaticResource NotNullToVisibilityConverter}}"/>

                        <TextBlock Text="Результат тестирования" FontSize="13"
           FontWeight="SemiBold" Foreground="#1E293B"
           Margin="0,0,0,10"
           Visibility="{Binding SelectedAssembly.Tests,
               Converter={StaticResource NotNullToVisibilityConverter}}"/>

                        <ItemsControl ItemsSource="{Binding SelectedAssembly.Tests}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Padding="12,10"
                    Margin="0,0,0,8">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Result}"
                                         Value="Пройдено">
                                                        <Setter Property="Background" Value="#F0FDF4"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Result}"
                                         Value="Не пройдено">
                                                        <Setter Property="Background" Value="#FEF2F2"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>

                                            <!-- Результат -->
                                            <TextBlock FontSize="13" FontWeight="Bold"
                               Margin="0,0,0,6">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Result}"
                                                 Value="Пройдено">
                                                                <Setter Property="Text" Value="✓ Пройдено"/>
                                                                <Setter Property="Foreground" Value="#16A34A"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Result}"
                                                 Value="Не пройдено">
                                                                <Setter Property="Text" Value="✗ Не пройдено"/>
                                                                <Setter Property="Foreground" Value="#EF4444"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!-- Тестировщик -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="Тестировщик: " FontSize="11"
                                   Foreground="#64748B"/>
                                                <TextBlock Text="{Binding Tester.FullName}"
                                   FontSize="11" Foreground="#1E293B"
                                   FontWeight="SemiBold"/>
                                            </StackPanel>

                                            <!-- Дата -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <TextBlock Text="Дата: " FontSize="11"
                                   Foreground="#64748B"/>
                                                <TextBlock Text="{Binding TestDate, StringFormat=dd.MM.yyyy HH:mm}"
                                   FontSize="11" Foreground="#475569"/>
                                            </StackPanel>

                                            <!-- Дефекты -->
                                            <StackPanel Visibility="{Binding Defects,
                                    Converter={StaticResource StringToVisibilityConverter}}">
                                                <TextBlock Text="Выявленные дефекты:"
                                   FontSize="11" Foreground="#64748B"
                                   Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding Defects}"
                                   FontSize="12" Foreground="#DC2626"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <!-- Примечания -->
                                            <StackPanel Visibility="{Binding Notes,
                                    Converter={StaticResource StringToVisibilityConverter}}"
                                Margin="0,6,0,0">
                                                <TextBlock Text="Примечания:"
                                   FontSize="11" Foreground="#64748B"
                                   Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding Notes}"
                                   FontSize="12" Foreground="#475569"
                                   TextWrapping="Wrap"/>
                                            </StackPanel>

                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Переделка — показывается только когда статус Доработка и есть позиции -->
                        <Border CornerRadius="10" Padding="14,12"
                                Margin="0,14,0,0" Background="#FFF7ED"
                                BorderBrush="#F59E0B" BorderThickness="1"
                                Visibility="{Binding DataContext.HasReworkItems,
                                    RelativeSource={RelativeSource AncestorType=UserControl},
                                    Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="⚠ Требуется замена деталей"
                                           FontSize="13" FontWeight="Bold"
                                           Foreground="#B45309" Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding DataContext.ReworkItems,
                                    RelativeSource={RelativeSource AncestorType=UserControl}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="White" CornerRadius="6"
                                                    Padding="10,8" Margin="0,0,0,6"
                                                    BorderBrush="#FDE68A" BorderThickness="1">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                        <TextBlock Text="Дата: "
                                                                   FontSize="11" Foreground="#64748B"/>
                                                        <TextBlock Text="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}"
                                                                   FontSize="11" Foreground="#94A3B8"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Снять: "
                                                                   FontSize="11" Foreground="#64748B"/>
                                                        <TextBlock FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="#DC2626">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="(без замены)"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding OldComponentId}" Value="{x:Null}">
                                                                            <Setter Property="Text" Value="(без замены)"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding OldComponent.Name}"
                                                                   FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="#DC2626"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                        <TextBlock Text="Установить: "
                                                                   FontSize="11" Foreground="#64748B"/>
                                                        <TextBlock Text="{Binding NewComponent.Name}"
                                                                   FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="#16A34A"/>
                                                        <TextBlock Text=" ×" FontSize="12" Foreground="#475569"/>
                                                        <TextBlock Text="{Binding Quantity}"
                                                                   FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="#475569"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Notes}"
                                                               FontSize="11" Foreground="#94A3B8"
                                                               Margin="0,4,0,0" TextWrapping="Wrap"
                                                               Visibility="{Binding Notes,
                                                                   Converter={StaticResource StringToVisibilityConverter}}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="Обратитесь к кладовщику для получения замены."
                                           FontSize="11" Foreground="#92400E"
                                           Margin="0,6,0,0" FontStyle="Italic"/>
                            </StackPanel>
                        </Border>

                        <!-- Выполненные замены деталей -->
                        <Border CornerRadius="10" Padding="14,12"
                                Margin="0,10,0,0" Background="#F0FDF4"
                                BorderBrush="#22C55E" BorderThickness="1"
                                Visibility="{Binding DataContext.HasCompletedReworkItems,
                                    RelativeSource={RelativeSource AncestorType=UserControl},
                                    Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="✓ Выполненные замены деталей"
                                           FontSize="13" FontWeight="Bold"
                                           Foreground="#15803D" Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding DataContext.CompletedReworkItems,
                                    RelativeSource={RelativeSource AncestorType=UserControl}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="White" CornerRadius="6"
                                                    Padding="10,8" Margin="0,0,0,6"
                                                    BorderBrush="#BBF7D0" BorderThickness="1">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                        <TextBlock Text="Дата: "
                                                                   FontSize="11" Foreground="#64748B"/>
                                                        <TextBlock Text="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}"
                                                                   FontSize="11" Foreground="#94A3B8"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Снято: "
                                                                   FontSize="11" Foreground="#64748B"/>
                                                        <TextBlock Text="{Binding OldComponent.Name}"
                                                                   FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="#DC2626"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                        <TextBlock Text="✓ Установлено: "
                                                                   FontSize="11" Foreground="#16A34A"/>
                                                        <TextBlock Text="{Binding NewComponent.Name}"
                                                                   FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="#15803D"/>
                                                        <TextBlock Text=" ×" FontSize="12" Foreground="#475569"/>
                                                        <TextBlock Text="{Binding Quantity}"
                                                                   FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="#475569"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Notes}"
                                                               FontSize="11" Foreground="#94A3B8"
                                                               Margin="0,4,0,0" TextWrapping="Wrap"
                                                               Visibility="{Binding Notes,
                                                                   Converter={StaticResource StringToVisibilityConverter}}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Документы -->
                        <TextBlock Text="Документы" FontSize="13"
           FontWeight="SemiBold" Foreground="#1E293B"
           Margin="0,14,0,10"/>

                        <Button Content="🏷 Этикетка / серийный номер"
        Command="{Binding DataContext.PrintLabelCommand,
            RelativeSource={RelativeSource AncestorType=UserControl}}"
        Style="{StaticResource PrimaryButton}"
        Background="#0F172A"
        HorizontalAlignment="Stretch"
        Margin="0,0,0,8"/>

                        <Button Content="📋 Техническое задание"
        Command="{Binding DataContext.PrintAssignmentCommand,
            RelativeSource={RelativeSource AncestorType=UserControl}}"
        Style="{StaticResource PrimaryButton}"
        Background="#475569"
        HorizontalAlignment="Stretch"
        Margin="0,0,0,8"/>

                        <Button Content="✅ Акт приёмки"
        Command="{Binding DataContext.PrintAcceptanceCommand,
            RelativeSource={RelativeSource AncestorType=UserControl}}"
        Style="{StaticResource PrimaryButton}"
        Background="#16A34A"
        HorizontalAlignment="Stretch"
        Margin="0,0,0,8"/>

                        <Button Content="🛡 Гарантийный талон"
        Command="{Binding DataContext.PrintWarrantyCommand,
            RelativeSource={RelativeSource AncestorType=UserControl}}"
        Style="{StaticResource PrimaryButton}"
        Background="#8B5CF6"
        HorizontalAlignment="Stretch"
        Margin="0,0,0,14"/>

                        <!-- Комплектующие -->
                        <TextBlock Text="Комплектующие" FontSize="13"
                                   FontWeight="SemiBold" Foreground="#1E293B"
                                   Margin="0,0,0,10"/>

                        <ItemsControl ItemsSource="{Binding SelectedAssembly.AssemblyComponents}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8FAFC"
                                            CornerRadius="8" Padding="12,10"
                                            Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Component.Name}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#1E293B"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Component.SKU}"
                                                           FontSize="11" Foreground="#94A3B8"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <Border Grid.Column="1"
                                                    Background="#3B82F6"
                                                    CornerRadius="12" Padding="8,3"
                                                    VerticalAlignment="Center"
                                                    Margin="8,0,0,0">
                                                <TextBlock FontSize="12"
                                                           Foreground="White"
                                                           FontWeight="SemiBold">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="x{0}">
                                                            <Binding Path="Quantity"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>