<UserControl x:Class="МаршрутСборки.Views.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:МаршрутСборки.ViewModels">
    <UserControl.DataContext>
        <vm:UsersViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <!-- Левая часть -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0" Background="White"
                    BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                    Padding="32,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Сотрудники" FontSize="22"
                                   FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="Управление учётными записями"
                                   FontSize="13" Foreground="#94A3B8"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="+ Добавить сотрудника"
                            Command="{Binding CreateCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Background="#3B82F6"/>
                </Grid>
            </Border>

            <!-- Таблица -->
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Users}"
                      SelectedItem="{Binding SelectedUser}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      Background="White"
                      RowBackground="White"
                      AlternatingRowBackground="#FAFAFA"
                      BorderThickness="0"
                      ColumnHeaderHeight="44"
                      RowHeight="52"
                      SelectionMode="Single"
                      CanUserResizeRows="False">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="Foreground" Value="#64748B"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="16,0"/>
                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#EFF6FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="16,0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Padding="{TemplateBinding Padding}"
                                            Background="{TemplateBinding Background}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Фамилия" Width="140"
                                        Binding="{Binding LastName}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#1E293B"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Имя" Width="120"
                                        Binding="{Binding FirstName}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#475569"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Логин" Width="130"
                                        Binding="{Binding Login}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#94A3B8"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="Роль" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="20" Padding="10,4"
                                        HorizontalAlignment="Left"
                                        Background="#EFF6FF">
                                    <TextBlock Text="{Binding Role.RoleName}"
                                               Foreground="#3B82F6"
                                               FontSize="12" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Панель действий -->
            <Border Grid.Row="2" Background="White"
                    BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                    Padding="32,14">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Деактивировать"
                            Command="{Binding DeactivateCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Background="#EF4444"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Правая панель — детали -->
        <Border Grid.Column="1"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1,0,0,0">
            <Grid>
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Visibility="{Binding SelectedUser,
                                Converter={StaticResource NullToVisibilityConverter}}">
                    <TextBlock Text="👥" FontSize="40"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Выберите сотрудника"
                               FontSize="14" Foreground="#94A3B8"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding SelectedUser,
                                  Converter={StaticResource NotNullToVisibilityConverter}}">
                    <StackPanel Margin="24">

                        <!-- Аватар и имя -->
                        <Border Width="64" Height="64"
                                CornerRadius="32" Background="#3B82F6"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,16">
                            <TextBlock Text="👤" FontSize="28"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="{Binding SelectedUser.FullName}"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="#1E293B" Margin="0,0,0,6"
                                   TextWrapping="Wrap"/>

                        <Border Background="#EFF6FF" CornerRadius="20"
                                Padding="10,4" HorizontalAlignment="Left"
                                Margin="0,0,0,20">
                            <TextBlock Text="{Binding SelectedUser.Role.RoleName}"
                                       Foreground="#3B82F6" FontSize="12"
                                       FontWeight="SemiBold"/>
                        </Border>

                        <Border Height="1" Background="#E2E8F0" Margin="0,0,0,16"/>

                        <TextBlock Text="Логин" FontSize="11"
                                   Foreground="#94A3B8" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SelectedUser.Login}"
                                   FontSize="14" Foreground="#1E293B"
                                   Margin="0,0,0,16"/>

                        <Border Height="1" Background="#E2E8F0" Margin="0,0,0,16"/>

                        <!-- Кнопка сброса пароля -->
                        <TextBlock Text="Управление" FontSize="13"
                                   FontWeight="SemiBold" Foreground="#1E293B"
                                   Margin="0,0,0,12"/>

                        <Button Content="Сбросить пароль"
                                Command="{Binding ResetPasswordCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Background="#F59E0B"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,10"/>

                        <Button Content="Деактивировать аккаунт"
                                Command="{Binding DeactivateCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Background="#EF4444"
                                HorizontalAlignment="Stretch"/>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>