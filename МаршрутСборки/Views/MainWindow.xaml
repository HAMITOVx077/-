<Window x:Class="МаршрутСборки.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:МаршрутСборки.ViewModels"
        xmlns:views="clr-namespace:МаршрутСборки.Views"
        Title="Маршрут сборки" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F1F5F9">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Боковое меню -->
        <Border Grid.Column="0" Background="#1E293B">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Логотип -->
                <Border Grid.Row="0" Padding="20,24"
                        BorderBrush="#334155" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="Маршрут сборки"
                                   Foreground="White" FontSize="16"
                                   FontWeight="Bold"/>
                        <TextBlock Text="ООО «Нью Ай Ти»"
                                   Foreground="#94A3B8" FontSize="11"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Пункты меню -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding MenuItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="8,2" CornerRadius="8" Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="#3B82F6"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#334155"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.SelectMenuItemCommand,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <StackPanel Orientation="Horizontal" Margin="14,10">
                                        <TextBlock Text="{Binding Icon}"
                                                   FontSize="16" Foreground="White"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="White" FontSize="14"
                                                   Margin="10,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Пользователь -->
                <Border Grid.Row="2" Padding="16,16"
                        BorderBrush="#334155" BorderThickness="0,1,0,0">
                    <StackPanel>
                        <TextBlock Text="{Binding UserFullName}"
                                   Foreground="White" FontSize="13"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding UserRole}"
                                   Foreground="#94A3B8" FontSize="11"
                                   Margin="0,2,0,10"/>
                        <Button Content="Выйти"
                                Command="{Binding LogoutCommand}"
                                Background="#334155" Foreground="#94A3B8"
                                BorderThickness="0" Padding="0,8"
                                Cursor="Hand" FontSize="12">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#EF4444"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Контент -->
        <Border Grid.Column="1" Background="#F1F5F9">
            <ContentControl Content="{Binding CurrentViewModel}">
                <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type vm:ProfileViewModel}">
                        <views:ProfileView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:AssembliesViewModel}">
                        <views:AssembliesView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:WarehouseViewModel}">
                        <views:WarehouseView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:TestingViewModel}">
                        <views:TestingView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:WarrantyViewModel}">
                        <views:WarrantyView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:UsersViewModel}">
                        <views:UsersView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
                        <views:ReportsView/>
                    </DataTemplate>
                </ContentControl.Resources>
            </ContentControl>
        </Border>
    </Grid>
</Window>