<UserControl x:Class="МаршрутСборки.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:МаршрутСборки.ViewModels"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">
    <UserControl.DataContext>
        <vm:ReportsViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                Padding="32,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Аналитика" FontSize="22"
                               FontWeight="Bold" Foreground="#1E293B"/>
                    <TextBlock Text="Ключевые показатели производства"
                               FontSize="13" Foreground="#94A3B8"
                               Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="Обновить"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Background="#3B82F6"/>
            </Grid>
        </Border>

        <!-- Фильтры + кнопки экспорта -->
        <Border Grid.Row="1" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                Padding="32,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Фильтр дат -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="Период:" FontSize="13" Foreground="#475569"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Border Background="#F8FAFC" BorderBrush="#E2E8F0"
                            BorderThickness="1" CornerRadius="8" Margin="0,0,8,0">
                        <DatePicker SelectedDate="{Binding DateFrom}" FontSize="13"
                                    Padding="8,8" BorderThickness="0" Background="Transparent"/>
                    </Border>
                    <TextBlock Text="—" FontSize="13" Foreground="#94A3B8"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Border Background="#F8FAFC" BorderBrush="#E2E8F0"
                            BorderThickness="1" CornerRadius="8">
                        <DatePicker SelectedDate="{Binding DateTo}" FontSize="13"
                                    Padding="8,8" BorderThickness="0" Background="Transparent"/>
                    </Border>
                </StackPanel>

                <!-- Фильтр по сотруднику -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Сборщик:" FontSize="13" Foreground="#475569"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Border Background="#F8FAFC" BorderBrush="#E2E8F0"
                            BorderThickness="1" CornerRadius="8" Width="180">
                        <ComboBox ItemsSource="{Binding Assemblers}"
                                  SelectedItem="{Binding SelectedAssemblerFilter}"
                                  BorderThickness="0" Background="Transparent"
                                  FontSize="13" Padding="8,6">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding FullName}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                        <Setter Property="Text" Value="Все сборщики"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Border>
                </StackPanel>

                <!-- Кнопки экспорта -->
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button Content="📝 Журнал в TXT"
                            Command="{Binding ExportEventLogTxtCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Background="#0EA5E9"
                            Margin="0,0,10,0"/>
                    <Button Content="📄 Отчёт по сборкам"
                            Command="{Binding ExportAssembliesReportCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Background="#8B5CF6"
                            Margin="0,0,10,0"/>
                    <Button Content="📦 Отчёт по складу"
                            Command="{Binding ExportWarehouseReportCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Background="#16A34A"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- KPI карточки -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Disabled"
                      HorizontalScrollBarVisibility="Auto">
            <StackPanel Orientation="Horizontal" Margin="32,20">

                <Border Background="White" BorderBrush="#E2E8F0"
                        BorderThickness="1" CornerRadius="12"
                        Padding="20,16" Margin="0,0,16,0" Width="160">
                    <StackPanel>
                        <TextBlock Text="Всего сборок" FontSize="12"
                                   Foreground="#94A3B8" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding TotalAssemblies}"
                                   FontSize="32" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="за период" FontSize="11"
                                   Foreground="#CBD5E1" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="White" BorderBrush="#E2E8F0"
                        BorderThickness="1" CornerRadius="12"
                        Padding="20,16" Margin="0,0,16,0" Width="160">
                    <StackPanel>
                        <TextBlock Text="Завершено" FontSize="12"
                                   Foreground="#94A3B8" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding CompletedAssemblies}"
                                   FontSize="32" FontWeight="Bold" Foreground="#16A34A"/>
                        <TextBlock Text="готово / отгружено" FontSize="11"
                                   Foreground="#CBD5E1" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="White" BorderBrush="#E2E8F0"
                        BorderThickness="1" CornerRadius="12"
                        Padding="20,16" Margin="0,0,16,0" Width="160">
                    <StackPanel>
                        <TextBlock Text="В работе" FontSize="12"
                                   Foreground="#94A3B8" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding InProgressAssemblies}"
                                   FontSize="32" FontWeight="Bold" Foreground="#3B82F6"/>
                        <TextBlock Text="сейчас собирается" FontSize="11"
                                   Foreground="#CBD5E1" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="White" BorderBrush="#E2E8F0"
                        BorderThickness="1" CornerRadius="12"
                        Padding="20,16" Margin="0,0,16,0" Width="160">
                    <StackPanel>
                        <TextBlock Text="Доработка" FontSize="12"
                                   Foreground="#94A3B8" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding ReworkAssemblies}"
                                   FontSize="32" FontWeight="Bold" Foreground="#EF4444"/>
                        <TextBlock Text="требуют исправления" FontSize="11"
                                   Foreground="#CBD5E1" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="White" BorderBrush="#E2E8F0"
                        BorderThickness="1" CornerRadius="12"
                        Padding="20,16" Margin="0,0,16,0" Width="160">
                    <StackPanel>
                        <TextBlock Text="Мало на складе" FontSize="12"
                                   Foreground="#94A3B8" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding LowStockCount}"
                                   FontSize="32" FontWeight="Bold" Foreground="#F59E0B"/>
                        <TextBlock Text="позиций комплектующих" FontSize="11"
                                   Foreground="#CBD5E1" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="White" BorderBrush="#E2E8F0"
                        BorderThickness="1" CornerRadius="12"
                        Padding="20,16" Width="160">
                    <StackPanel>
                        <TextBlock Text="Открытые гарантии" FontSize="12"
                                   Foreground="#94A3B8" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding OpenWarrantyCases}"
                                   FontSize="32" FontWeight="Bold" Foreground="#8B5CF6"/>
                        <TextBlock Text="активных обращений" FontSize="11"
                                   Foreground="#CBD5E1" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Нижняя часть: статистика по сборщикам + журнал событий -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
        <Grid Margin="32,0,32,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="200"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="200"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="300"/>
            </Grid.RowDefinitions>

            <!-- Заголовок статистики по сборщикам -->
            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="Производительность сборщиков"
                       FontSize="15" FontWeight="SemiBold"
                       Foreground="#1E293B" Margin="0,0,0,10"/>

            <!-- График по сборщикам -->
            <Border Grid.Row="1" Grid.Column="0"
                    Background="White" BorderBrush="#E2E8F0"
                    BorderThickness="1" CornerRadius="12">
                <lvc:CartesianChart Series="{Binding AssemblerSeries}"
                                    XAxes="{Binding AssemblerXAxes}"
                                    YAxes="{Binding YAxes}"
                                    LegendPosition="Right"
                                    Margin="8"/>
            </Border>

            <!-- Заголовок таблицы сборщиков -->
            <TextBlock Grid.Row="0" Grid.Column="2"
                       Text="Таблица по сборщикам"
                       FontSize="15" FontWeight="SemiBold"
                       Foreground="#1E293B" Margin="0,0,0,10"/>

            <!-- Таблица статистики сборщиков -->
            <Border Grid.Row="1" Grid.Column="2"
                    Background="White" BorderBrush="#E2E8F0"
                    BorderThickness="1" CornerRadius="12">
                <DataGrid ItemsSource="{Binding AssemblerStats}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          Background="White" RowBackground="White"
                          AlternatingRowBackground="#FAFAFA"
                          BorderThickness="0"
                          ColumnHeaderHeight="36" RowHeight="36"
                          CanUserResizeRows="False">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="#64748B"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="12,0"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="12,0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="{TemplateBinding Padding}"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Сборщик" Width="*" Binding="{Binding Name}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="#1E293B"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Всего" Width="55" Binding="{Binding Total}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#475569"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Готово" Width="58" Binding="{Binding Completed}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#16A34A"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Доработка" Width="75" Binding="{Binding Rework}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#EF4444"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="% выполн." Width="75" Binding="{Binding CompletionRate}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#8B5CF6"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Кнопка экспорта таблицы сборщиков -->
            <Button Grid.Row="2" Grid.Column="2"
                    Content="📊 Экспорт таблицы в PDF"
                    Command="{Binding ExportAssemblerStatsPdfCommand}"
                    Style="{StaticResource PrimaryButton}"
                    Background="#8B5CF6"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"/>

            <!-- Складские операции -->
            <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                       Text="Складские операции за период"
                       FontSize="15" FontWeight="SemiBold"
                       Foreground="#1E293B" Margin="0,0,0,10"/>

            <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3"
                    Background="White" BorderBrush="#E2E8F0"
                    BorderThickness="1" CornerRadius="12"
                    Margin="0,0,0,8">
                <DataGrid ItemsSource="{Binding WarehouseOps}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          Background="White" RowBackground="White"
                          AlternatingRowBackground="#FAFAFA"
                          BorderThickness="0"
                          ColumnHeaderHeight="36" RowHeight="40"
                          CanUserResizeRows="False" MaxHeight="200">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="#64748B"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="12,0"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="12,0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="{TemplateBinding Padding}"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Дата" Width="120"
                                            Binding="{Binding OperationDate, StringFormat=dd.MM.yyyy HH:mm}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Тип" Width="110"
                                            Binding="{Binding OperationType}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#3B82F6"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Комплектующее" Width="*"
                                            Binding="{Binding Component.Name}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#1E293B"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Кол-во" Width="70"
                                            Binding="{Binding Quantity}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#475569"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Сборка" Width="130"
                                            Binding="{Binding Assembly.AssemblyNumber}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#8B5CF6"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Кладовщик" Width="140"
                                            Binding="{Binding User.FullName}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#475569"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Документ" Width="160"
                                            Binding="{Binding DocumentRef}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Кнопка экспорта складских операций в TXT -->
            <Button Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3"
                    Content="📝 Экспорт складских операций в TXT"
                    Command="{Binding ExportWarehouseOpsTxtCommand}"
                    Style="{StaticResource PrimaryButton}"
                    Background="#0EA5E9"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,16"/>

            <!-- Заголовок журнала событий -->
            <TextBlock Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3"
                       Text="Журнал событий за период"
                       FontSize="15" FontWeight="SemiBold"
                       Foreground="#1E293B" Margin="0,0,0,10"/>

            <!-- Журнал событий -->
            <Border Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="3"
                    Background="White" BorderBrush="#E2E8F0"
                    BorderThickness="1" CornerRadius="12">
                <DataGrid ItemsSource="{Binding RecentEvents}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          Background="White" RowBackground="White"
                          AlternatingRowBackground="#FAFAFA"
                          BorderThickness="0"
                          ColumnHeaderHeight="40" RowHeight="44"
                          CanUserResizeRows="False">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="#64748B"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="16,0"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="16,0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="{TemplateBinding Padding}"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Дата и время" Width="150"
                                            Binding="{Binding ActionTime, StringFormat=dd.MM.yyyy HH:mm}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Сотрудник" Width="160"
                                            Binding="{Binding User.FullName}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="#1E293B"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Действие" Width="160"
                                            Binding="{Binding ActionType}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#3B82F6"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Описание" Width="*"
                                            Binding="{Binding Description}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#475569"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
