<UserControl x:Class="МаршрутСборки.Views.TestingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:МаршрутСборки.ViewModels">
    <UserControl.DataContext>
        <vm:TestingViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                Padding="32,20">
            <StackPanel>
                <TextBlock Text="Тестирование" FontSize="22"
                           FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock Text="Контроль качества собранных изделий"
                           FontSize="13" Foreground="#94A3B8"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Список + панель деталей -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Список — ожидают тестирования -->
            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding Assemblies}"
                      SelectedItem="{Binding SelectedAssembly}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      Background="White"
                      RowBackground="White"
                      AlternatingRowBackground="#FAFAFA"
                      BorderThickness="0"
                      ColumnHeaderHeight="44"
                      RowHeight="52"
                      SelectionMode="Single"
                      CanUserResizeRows="False">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="Foreground" Value="#64748B"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="16,0"/>
                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#EFF6FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="16,0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Padding="{TemplateBinding Padding}"
                                            Background="{TemplateBinding Background}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Номер сборки" Width="140"
                                        Binding="{Binding AssemblyNumber}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#1E293B"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Клиент" Width="*"
                                        Binding="{Binding ClientName}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#475569"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="Статус" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="20" Padding="10,4"
                                        HorizontalAlignment="Left"
                                        Background="{Binding Status,
                                            Converter={StaticResource StatusColorConverter}}">
                                    <TextBlock Text="{Binding Status}"
                                               Foreground="White" FontSize="12"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Сборщик" Width="160"
                                        Binding="{Binding Assembler.FullName}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#475569"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Срок" Width="100"
                                        Binding="{Binding Deadline, StringFormat=dd.MM.yyyy}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#94A3B8"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Панель деталей выбранной сборки -->
            <Border Grid.Column="1"
                    Background="#F8FAFC"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1,0,0,0">
                <!-- Заглушка когда ничего не выбрано -->
                <TextBlock Text="Выберите сборку&#x0a;для просмотра деталей"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center"
                           FontSize="13" Foreground="#CBD5E1"
                           Visibility="{Binding SelectedAssembly,
                               Converter={StaticResource NullToVisibilityConverter}}"/>
            </Border>

            <!-- Детали (поверх заглушки, видны только при выборе) -->
            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          Background="#F8FAFC"
                          Padding="20,16"
                          Visibility="{Binding SelectedAssembly,
                              Converter={StaticResource NotNullToVisibilityConverter}}">
                <StackPanel DataContext="{Binding SelectedAssembly}">
                    <!-- Номер -->
                    <TextBlock Text="{Binding AssemblyNumber}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="#1E293B" Margin="0,0,0,4"/>
                    <!-- Клиент -->
                    <TextBlock Text="{Binding ClientName}"
                               FontSize="13" Foreground="#475569"
                               Margin="0,0,0,12"/>

                    <!-- Статус -->
                    <Border CornerRadius="20" Padding="10,4"
                            HorizontalAlignment="Left" Margin="0,0,0,12"
                            Background="{Binding Status,
                                Converter={StaticResource StatusColorConverter}}">
                        <TextBlock Text="{Binding Status}"
                                   Foreground="White" FontSize="12"
                                   FontWeight="SemiBold"/>
                    </Border>

                    <!-- Разделитель -->
                    <Border Height="1" Background="#E2E8F0" Margin="0,0,0,12"/>

                    <!-- Сборщик -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Сборщик:" FontSize="12"
                                   Foreground="#94A3B8" Width="80"/>
                        <TextBlock Text="{Binding Assembler.FullName}"
                                   FontSize="12" Foreground="#1E293B"
                                   FontWeight="SemiBold" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Срок -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Срок:" FontSize="12"
                                   Foreground="#94A3B8" Width="80"/>
                        <TextBlock Text="{Binding Deadline, StringFormat=dd.MM.yyyy}"
                                   FontSize="12" Foreground="#1E293B"/>
                    </StackPanel>

                    <!-- Приоритет -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="Приоритет:" FontSize="12"
                                   Foreground="#94A3B8" Width="80"/>
                        <TextBlock Text="{Binding Priority}"
                                   FontSize="12" Foreground="#1E293B"/>
                    </StackPanel>

                    <!-- Разделитель -->
                    <Border Height="1" Background="#E2E8F0" Margin="0,0,0,12"/>

                    <!-- Заголовок состава -->
                    <TextBlock Text="Состав сборки:"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#64748B" Margin="0,0,0,8"/>

                    <!-- Список компонентов -->
                    <ItemsControl ItemsSource="{Binding AssemblyComponents}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Component.Name}"
                                               FontSize="12" Foreground="#334155"
                                               TextWrapping="Wrap"/>
                                    <Border Grid.Column="1"
                                            Background="#E0E7FF" CornerRadius="10"
                                            Padding="6,2" Margin="6,0,0,0">
                                        <TextBlock FontSize="11" Foreground="#4338CA"
                                                   FontWeight="SemiBold">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="×{0}">
                                                    <Binding Path="Quantity"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- История замен деталей (видна только если были доработки) -->
                    <Border Height="1" Background="#E2E8F0" Margin="0,12,0,12"
                            Visibility="{Binding DataContext.HasReworkHistory,
                                RelativeSource={RelativeSource AncestorType=UserControl},
                                Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <Border CornerRadius="8" Padding="12,10"
                            Background="#FFF7ED" BorderBrush="#F59E0B" BorderThickness="1"
                            Visibility="{Binding DataContext.HasReworkHistory,
                                RelativeSource={RelativeSource AncestorType=UserControl},
                                Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="⚠ История замен деталей"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="#B45309" Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding DataContext.AllReworkItems,
                                RelativeSource={RelativeSource AncestorType=UserControl}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,6" Padding="8,6"
                                                CornerRadius="6" BorderThickness="1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#F0FDF4"/>
                                                    <Setter Property="BorderBrush" Value="#BBF7D0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsIssued}" Value="False">
                                                            <Setter Property="Background" Value="White"/>
                                                            <Setter Property="BorderBrush" Value="#FDE68A"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                                    <!-- Ожидает выдачи (IsIssued=false) -->
                                                    <TextBlock Text="⏳ Ожидает выдачи"
                                                               FontSize="11" FontWeight="Bold" Foreground="#92400E">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsIssued}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <!-- Комплектующие выданы (IsIssued=true) -->
                                                    <TextBlock Text="✓ Комплектующие выданы"
                                                               FontSize="11" FontWeight="Bold" Foreground="#15803D">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsIssued}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding CreatedAt, StringFormat=' — dd.MM.yyyy'}"
                                                               FontSize="11" Foreground="#94A3B8"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="Снято: " FontSize="11" Foreground="#64748B"/>
                                                    <TextBlock Text="{Binding OldComponent.Name}"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               Foreground="#DC2626"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <TextBlock Text="Установлено: " FontSize="11" Foreground="#64748B"/>
                                                    <TextBlock Text="{Binding NewComponent.Name}"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               Foreground="#15803D"/>
                                                    <TextBlock Text=" ×" FontSize="11" Foreground="#475569"/>
                                                    <TextBlock Text="{Binding Quantity}"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               Foreground="#475569"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Панель действий для ожидающих -->
        <Border Grid.Row="2" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                Padding="32,14">
            <StackPanel Orientation="Horizontal">
                <Button Content="Внести результат тестирования"
                        Command="{Binding SaveResultCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Background="#8B5CF6"/>
            </StackPanel>
        </Border>

        <!-- Заголовок секции завершённых -->
        <Border Grid.Row="3" Background="#F8FAFC"
                BorderBrush="#E2E8F0" BorderThickness="0,2,0,1"
                Padding="32,12">
            <TextBlock Text="Завершённые тестирования (последние 50)"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="#1E293B"/>
        </Border>

        <!-- Список завершённых -->
        <DataGrid Grid.Row="4"
                  ItemsSource="{Binding CompletedAssemblies}"
                  SelectedItem="{Binding SelectedCompletedAssembly}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  Background="White"
                  RowBackground="White"
                  AlternatingRowBackground="#FAFAFA"
                  BorderThickness="0"
                  ColumnHeaderHeight="40"
                  RowHeight="48"
                  SelectionMode="Single"
                  CanUserResizeRows="False">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="Foreground" Value="#64748B"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="16,0"/>
                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Cursor" Value="Hand"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#EFF6FF"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F8FAFC"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="16,0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border Padding="{TemplateBinding Padding}"
                                        Background="{TemplateBinding Background}">
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Номер сборки" Width="140"
                                    Binding="{Binding AssemblyNumber}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="#1E293B"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Клиент" Width="*"
                                    Binding="{Binding ClientName}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#475569"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="Статус" Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="20" Padding="10,4"
                                    HorizontalAlignment="Left"
                                    Background="{Binding Status,
                                        Converter={StaticResource StatusColorConverter}}">
                                <TextBlock Text="{Binding Status}"
                                           Foreground="White" FontSize="12"
                                           FontWeight="SemiBold"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Результат" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="13" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}"
                                                         Value="Готова">
                                                <Setter Property="Text" Value="✓ Пройдено"/>
                                                <Setter Property="Foreground" Value="#16A34A"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}"
                                                         Value="Требует доработки">
                                                <Setter Property="Text" Value="✗ Не пройдено"/>
                                                <Setter Property="Foreground" Value="#EF4444"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}"
                                                         Value="Отгружена">
                                                <Setter Property="Text" Value="✓ Отгружена"/>
                                                <Setter Property="Foreground" Value="#3B82F6"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Тестировщик" Width="160"
                                    Binding="{Binding Tests[0].Tester.FullName}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#475569"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Дата теста" Width="110"
                                    Binding="{Binding Tests[0].TestDate, StringFormat=dd.MM.yyyy}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#94A3B8"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Панель действий для завершённых -->
        <Border Grid.Row="5" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                Padding="32,14">
            <StackPanel Orientation="Horizontal">
                <Button Content="📄 Акт тестирования"
                        Command="{Binding PrintTestActCompletedCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Background="#475569"/>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>