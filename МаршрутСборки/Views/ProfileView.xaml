<UserControl x:Class="МаршрутСборки.Views.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:МаршрутСборки.Helpers">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32" MaxWidth="560">

            <TextBlock Text="Личный кабинет" FontSize="24"
                       FontWeight="Bold" Foreground="#1E293B"
                       Margin="0,0,0,24"/>

            <!-- Карточка профиля -->
            <Border Background="White" CornerRadius="12"
                    Padding="24" Margin="0,0,0,20"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="72" Height="72"
                            CornerRadius="36" Background="#3B82F6"
                            Margin="0,0,20,0">
                        <TextBlock Text="👤" FontSize="32"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding FullName}"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="#1E293B"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <Border Background="#EFF6FF" CornerRadius="20"
                                    Padding="10,4">
                                <TextBlock Text="{Binding RoleName}"
                                           Foreground="#3B82F6"
                                           FontSize="12" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="Логин: " Foreground="#94A3B8"
                                       FontSize="13"/>
                            <TextBlock Text="{Binding Login}"
                                       Foreground="#475569" FontSize="13"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Карточка папки сохранения -->
            <Border Background="White" CornerRadius="12"
                    Padding="24" Margin="0,0,0,20"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Папка для сохранения документов" FontSize="16"
                               FontWeight="SemiBold" Foreground="#1E293B"
                               Margin="0,0,0,12"/>

                    <Border Background="#F8FAFC" BorderBrush="#E2E8F0"
                            BorderThickness="1" CornerRadius="8" Padding="12,10"
                            Margin="0,0,0,14">
                        <TextBlock Text="{Binding OutputDirectoryDisplay}"
                                   FontSize="13" Foreground="#475569"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="📁 Выбрать папку"
                                Command="{Binding ChooseDirectoryCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Background="#3B82F6"
                                Margin="0,0,10,0"/>
                        <Button Content="По умолчанию (Рабочий стол)"
                                Command="{Binding SetDefaultDirectoryCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Background="#64748B"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Карточка смены пароля -->
            <Border Background="White" CornerRadius="12"
                    Padding="24"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Смена пароля" FontSize="16"
                               FontWeight="SemiBold" Foreground="#1E293B"
                               Margin="0,0,0,20"/>

                    <TextBlock Text="Текущий пароль" FontSize="13"
                               Foreground="#475569" Margin="0,0,0,6"/>
                    <Border Background="#F8FAFC" BorderBrush="#E2E8F0"
                            BorderThickness="1" CornerRadius="8"
                            Margin="0,0,0,16">
                        <PasswordBox x:Name="CurrentPasswordBox"
                                     FontSize="14" Padding="12,10"
                                     BorderThickness="0" Background="Transparent"
                                     PasswordChanged="CurrentPassword_Changed"/>
                    </Border>

                    <TextBlock Text="Новый пароль" FontSize="13"
                               Foreground="#475569" Margin="0,0,0,6"/>
                    <Border Background="#F8FAFC" BorderBrush="#E2E8F0"
                            BorderThickness="1" CornerRadius="8"
                            Margin="0,0,0,16">
                        <PasswordBox x:Name="NewPasswordBox"
                                     FontSize="14" Padding="12,10"
                                     BorderThickness="0" Background="Transparent"
                                     PasswordChanged="NewPassword_Changed"/>
                    </Border>

                    <TextBlock Text="Подтверждение пароля" FontSize="13"
                               Foreground="#475569" Margin="0,0,0,6"/>
                    <Border Background="#F8FAFC" BorderBrush="#E2E8F0"
                            BorderThickness="1" CornerRadius="8"
                            Margin="0,0,0,20">
                        <PasswordBox x:Name="ConfirmPasswordBox"
                                     FontSize="14" Padding="12,10"
                                     BorderThickness="0" Background="Transparent"
                                     PasswordChanged="ConfirmPassword_Changed"/>
                    </Border>

                    <Border CornerRadius="8" Padding="12,10"
                            Margin="0,0,0,16"
                            Visibility="{Binding Message,
                                Converter={StaticResource StringToVisibilityConverter}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                        <Setter Property="Background" Value="#F0FDF4"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                        <Setter Property="Background" Value="#FEF2F2"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding Message}" FontSize="13">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                            <Setter Property="Foreground" Value="#16A34A"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                            <Setter Property="Foreground" Value="#DC2626"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <Button Content="Сменить пароль"
                            Command="{Binding ChangePasswordCommand}"
                            FontSize="14" FontWeight="SemiBold"
                            Background="#3B82F6" Foreground="White"
                            BorderThickness="0" Padding="0,12"
                            Cursor="Hand" HorizontalAlignment="Left"
                            Width="200" Height="27">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#2563EB"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Background" Value="#CBD5E1"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>