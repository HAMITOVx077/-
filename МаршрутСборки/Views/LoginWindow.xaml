<Window x:Class="МаршрутСборки.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:МаршрутСборки.ViewModels"
        Title="Маршрут сборки — Вход"
        Height="550" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F8FAFC">
    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <Grid>
        <StackPanel VerticalAlignment="Center" Margin="48,0">

            <!-- Логотип -->
            <Image Source="/Assets/logo_black.png"
       Width="80" Height="80"
       HorizontalAlignment="Center"
       Margin="0,0,0,16"
       RenderOptions.BitmapScalingMode="HighQuality"/>

            <TextBlock Text="Маршрут сборки"
           FontSize="26" FontWeight="Bold"
           Foreground="#1E293B"
           HorizontalAlignment="Center"/>

            <TextBlock Text="ООО «Нью Ай Ти»"
           FontSize="13" Foreground="#64748B"
           HorizontalAlignment="Center"
           Margin="0,4,0,40"/>

            <TextBlock Text="Логин" FontSize="13" Foreground="#475569" Margin="0,0,0,6"/>
            <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8">
                <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="14" Padding="12,10"
                         BorderThickness="0" Background="Transparent"/>
            </Border>

            <TextBlock Text="Пароль" FontSize="13" Foreground="#475569" Margin="0,16,0,6"/>
            <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8">
                <PasswordBox x:Name="PasswordBox"
                             FontSize="14" Padding="12,10"
                             BorderThickness="0" Background="Transparent"
                             PasswordChanged="PasswordBox_PasswordChanged"/>
            </Border>

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#EF4444" FontSize="13"
                       Margin="0,12,0,0"
                       TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage,
                           Converter={StaticResource StringToVisibilityConverter}}"/>

            <Button Content="Войти"
                    Command="{Binding LoginCommand}"
                    FontSize="15" FontWeight="SemiBold"
                    Background="#3B82F6" Foreground="White"
                    BorderThickness="0" Padding="0,14"
                    Margin="0,24,0,0" Cursor="Hand" Height="35">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2563EB"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

        </StackPanel>
    </Grid>
</Window>